# Hermes Switch Manager — example environment (PLACEHOLDERS ONLY, never real values)
# Copy to .env and fill in before `docker compose up`.

# Backend
DATABASE_URL=sqlite:///./switches.db
OPENAI_API_KEY=sk-your-openai-key-here
SSH_USERNAME=admin
SSH_PASSWORD=change-me-on-first-run
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
