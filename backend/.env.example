# Database
DATABASE_URL=sqlite:///./switches.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/hermes

# OpenAI / AI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# SSH Credentials (default for network devices)
SSH_USERNAME=admin
SSH_PASSWORD=your-password
SSH_TIMEOUT=30

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Containerlab
CLAB_DIR=/etc/containerlab/lab

# Logging
LOG_LEVEL=INFO
